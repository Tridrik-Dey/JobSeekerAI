# Environment Configuration
# Copy this file to .env and fill in your actual API keys

# AI Provider Selection
# Options: openai, nvidia, mock
AI_PROVIDER=openai

# OpenAI API Key (if using OpenAI or OpenRouter)
# Get your key from: https://platform.openai.com/api-keys
# Or from OpenRouter: https://openrouter.ai/
OPENAI_API_KEY=your_openai_api_key_here

# NVIDIA API Key (if using NVIDIA)
# Get your key from: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and replace the placeholder values with your actual API keys
# 3. Choose your AI provider by setting AI_PROVIDER to: openai, nvidia, or mock
# 4. Never commit your .env file to version control (it's in .gitignore)
